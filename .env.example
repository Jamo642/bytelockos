# ByteLock OS Environment Configuration

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/bytelock_os
REDIS_URL=redis://localhost:6379/0

# AI & LLM Configuration
LLM_PROVIDER=anthropic  # Options: openai, anthropic, local
LLM_API_KEY=sk-...
LLM_MODEL=claude-3-haiku-20240307
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Cost & Safety Configuration
COST_THRESHOLD=50  # $ amount triggering HITL approval
ENABLE_MULTI_AGENT_DEBATE=true
DEBATE_TURN_LIMIT=2
ENABLE_MEMORY_POISONING_DEFENSE=true

# UI & API Configuration
API_PORT=8000
UI_PORT=3000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Security & TLS
ENABLE_MTLS=false
TLS_CERT_PATH=/etc/bytelock/certs/server.crt
TLS_KEY_PATH=/etc/bytelock/certs/server.key
TLS_CA_CERT_PATH=/etc/bytelock/certs/ca.crt

# Logging & Debug
LOG_LEVEL=INFO
DEBUG_MODE=false
ENABLE_PROFILING=false

# Connector Configuration
SPLUNK_API_URL=https://your-splunk-instance:8089
SPLUNK_API_TOKEN=
CROWDSTRIKE_API_URL=https://api.us-2.crowdstrike.com
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Syslog Configuration
SYSLOG_LISTEN_PORT=514
SYSLOG_LISTEN_ADDRESS=0.0.0.0
SYSLOG_PROTOCOL=udp  # Options: udp, tcp

# Vector Database (for RAG/Memory)
VECTOR_DB_TYPE=weaviate  # Options: weaviate, pinecone, milvus
VECTOR_DB_URL=http://localhost:8080
VECTOR_DB_API_KEY=

# Forensics & DFIR
AUTOPSY_API_URL=http://localhost:9999
ENABLE_FORENSICS=true

# Deployment Mode
ENVIRONMENT=development  # Options: development, staging, production
NODE_ENV=development
